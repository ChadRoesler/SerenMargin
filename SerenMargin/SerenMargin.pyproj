<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>b1e7c0de-5e12-4a7b-9f3a-5e7e7a5e7e7a</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <!-- Run python -m seren_margin when you hit F5 -->
    <StartupFile>seren_margin\__main__.py</StartupFile>
    <SearchPath>.</SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>SerenMargin</Name>
    <RootNamespace>seren_margin</RootNamespace>
    <InterpreterId>Global|PythonCore|3.11</InterpreterId>
    <IsWindowsApplication>False</IsWindowsApplication>
    <Description>Private notes-to-self for an AI assistant. Standalone, opt-in, opinionated.</Description>
    <TestFramework>Pytest</TestFramework>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="seren_margin\__init__.py" />
    <Compile Include="seren_margin\__main__.py" />
    <Compile Include="seren_margin\app.py" />
    <Compile Include="seren_margin\config.py" />
    <Compile Include="seren_margin\models.py" />
    <Compile Include="seren_margin\store.py" />
    <Compile Include="tests\test_smoke.py" />
    <Compile Include="tests\test_config.py" />
    <Compile Include="tests\__init__.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="seren_margin\" />
    <Folder Include="tests\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="pyproject.toml" />
    <Content Include="seren-margin.yaml.sample" />
    <Content Include="seren-margin.service.sample" />
  </ItemGroup>
  <ItemGroup>
    <InterpreterReference Include="Global|PythonCore|3.11" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>